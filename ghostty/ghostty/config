theme = Gruvbox Dark

font-size = 15
font-codepoint-map = U+E900-U+E904=icomoon

shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false

window-padding-x = 14
window-padding-y = 14

keybind = ctrl+shift+h=new_split:left
keybind = ctrl+shift+j=new_split:down
keybind = ctrl+shift+k=new_split:up
keybind = ctrl+shift+l=new_split:right

keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right

keybind = ctrl+opt+h=resize_split:left,20
keybind = ctrl+opt+j=resize_split:down,20
keybind = ctrl+opt+k=resize_split:up,20
keybind = ctrl+opt+l=resize_split:right,20

